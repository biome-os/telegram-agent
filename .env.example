# Orchestrator
ORCHESTRATOR_URL=http://localhost:8000

# Telegram Bot (required)
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# Inbound routing — set to enable forwarding user messages to another agent
TELEGRAM_ROUTING_TARGET=
# e.g. TELEGRAM_ROUTING_TARGET=task-planner-agent

# Webhook mode (leave empty to use long-polling)
TELEGRAM_WEBHOOK_URL=
# e.g. TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
TELEGRAM_WEBHOOK_SECRET=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Task routing timeout (seconds)
TASK_TIMEOUT_S=60

# Logging
LOG_LEVEL=INFO
